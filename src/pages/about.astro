---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillBadge from "../components/SkillBadge.astro";

const skillCategories = [
  {
    title: "Auth",
    icon: "shield",
    skills: ["JWT", "OAuth 2.0"],
  },
  {
    title: "Code Orchestration",
    icon: "server",
    skills: ["Temporal.io"],
  },
  {
    title: "Databases",
    icon: "database",
    skills: ["MongoDB", "MySQL", "PostgreSQL", "Redis / Valkey"],
  },
  {
    title: "Design Patterns",
    icon: "shield",
    skills: ["Domain-Driven Design", "Microservices", "Test-Driven Development"],
  },
  {
    title: "Infrastructure",
    icon: "cloud",
    skills: ["AWS", "Cloudflare", "Docker", "GCP", "Kubernetes", "Nginx", "Terraform"],
  },
  {
    title: "Language Frameworks",
    icon: "server",
    skills: ["Bun", "Node.js"],
  },
  {
    title: "Languages",
    icon: "code",
    skills: ["Bash", "JavaScript", "SQL", "TypeScript"],
  },
  {
    title: "Message Queueing",
    icon: "layers",
    skills: ["NSQ", "RabbitMQ"],
  },
  {
    title: "Protocols",
    icon: "server",
    skills: ["GraphQL", "REST", "Socket.io"],
  },
];

const interests = [
  { name: "AI", icon: "🤖" },
  { name: "Astrophysics", icon: "🔭" },
  { name: "Chess", icon: "♟️" },
  { name: "Cybersecurity", icon: "🔒" },
  { name: "F1", icon: "🏎️" },
  { name: "Football", icon: "⚽" },
  { name: "IndyCar", icon: "🏁" },
  { name: "MotoGP", icon: "🏍️" },
  { name: "NFL", icon: "🏈" },
  { name: "Swimming", icon: "🏊" },
  { name: "System Design", icon: "🏗️" },
  { name: "World Superbike", icon: "🏍️" },
  { name: "WRC", icon: "🚗" },
];
const languages = [
  { name: "Portuguese", level: "Native", icon: "🇵🇹" },
  { name: "English", level: "C2 Proficiency", icon: "🇬🇧" },
];

const iconMap: Record<string, string> = {
  code: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`,
  server: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>`,
  database: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>`,
  cloud: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path></svg>`,
  layers: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
};
---

<BaseLayout
  title="About — José Carlos Brandão"
  description="Learn about José Carlos Brandão's technical skills, interests, and background as a Senior Backend Engineer."
>
  <section class="section">
    <h1 class="page-title animate-on-scroll">
      About <span class="gradient-text">Me</span>
    </h1>

    <div class="bio animate-on-scroll">
      <p>
        I'm a software engineer based in Braga, Portugal, with over 7 years of experience
        building production systems that handle real-world complexity. My career has spanned
        conversational AI, healthcare tech, and fintech — always with a focus on backend
        architecture, clean code, and systems that scale.
      </p>
      <p>
        Currently at <a href="https://uphold.com" target="_blank" rel="noopener noreferrer">Uphold</a>,
        I'm working on neobanking features in the digital payments team — high transaction volume,
        multiple jurisdictions, and strict AML compliance. Previously at
        <a href="https://agentifai.com" target="_blank" rel="noopener noreferrer">AgentifAI</a>,
        I was a key contributor to the development of Gen AI chat and voice bots that helped users manage medical
        appointments, check balances, unlock contracts, and transfer funds.
      </p>
      <p>
        I hold a Master's degree from Universidade do Minho, where my dissertation focused on
        building a <a href="http://www.pvsioweb.org" target="_blank" rel="noopener noreferrer">PVSio-web</a> simulator.
        I'm fluent in English (C2 Cambridge certified) and Portuguese.
      </p>
    </div>

    <!-- Skills Grid -->
    <h2 class="section-title animate-on-scroll">Technical Skills</h2>
    <div class="skills-grid">
      {skillCategories.map((category) => (
        <div class="skill-category animate-on-scroll">
          <div class="skill-category-header">
            <span class="skill-icon" set:html={iconMap[category.icon]} />
            <h3>{category.title}</h3>
          </div>
          <div class="skill-badges">
            {category.skills.map((skill) => (
              <SkillBadge name={skill} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Interests -->
    <h2 class="section-title animate-on-scroll">Interests</h2>
    <div class="languages-grid">
      {interests.map((interest) => (
        <div class="language-card animate-on-scroll">
          <span class="language-name"><span class="card-icon">{interest.icon}</span> {interest.name}</span>
        </div>
      ))}
    </div>

    <!-- Languages -->
    <h2 class="section-title animate-on-scroll">Languages</h2>
    <div class="languages-grid">
      {languages.map((lang) => (
        <div class="language-card animate-on-scroll">
          <span class="language-name"><span class="card-icon">{lang.icon}</span> {lang.name}</span>
          <span class="language-level">{lang.level}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  .bio {
    max-width: 48rem;
    margin-bottom: 3rem;
  }

  .bio p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .skill-category-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .skill-category-header h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .skill-icon {
    color: var(--color-primary, #6366f1);
    display: flex;
  }

  .skill-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

.languages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .language-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .language-card:hover {
    border-color: var(--border-hover);
  }

  .language-name {
    display: inline-flex;
    align-items: center;
    gap: 0.44rem;
    font-weight: 500;
    color: var(--text);
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .language-level {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
