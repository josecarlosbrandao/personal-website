---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.jpg";
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-portrait animate-on-scroll">
      <Image src={portrait} alt="José Carlos Brandão" width={180} height={180} class="portrait-img" />
    </div>
    <p class="hero-greeting animate-on-scroll">Hello, I'm</p>
    <h1 class="hero-name animate-on-scroll">
      <span class="gradient-text">José Carlos Brandão</span>
    </h1>
    <p class="hero-title animate-on-scroll">Senior Backend Engineer</p>
    <p class="hero-subtitle animate-on-scroll">On the road to Fellow Engineer</p>
    <p class="hero-bio animate-on-scroll">
      Passionate about building robust, scalable systems. Currently crafting neobanking
      solutions at <a href="https://uphold.com" target="_blank" rel="noopener noreferrer">Uphold</a>.
      7+ years turning complex problems into elegant code across fintech, healthcare, and conversational AI.
    </p>
    <div class="hero-links animate-on-scroll">
      <a href="https://linkedin.com/in/josecarlosbg94" target="_blank" rel="noopener noreferrer" class="hero-btn primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a href="https://github.com/josecarlosbrandao" target="_blank" rel="noopener noreferrer" class="hero-btn secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub (Work)
      </a>
      <a href="https://github.com/zecarlos94" target="_blank" rel="noopener noreferrer" class="hero-btn secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub (Personal)
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 4rem);
    display: flex;
    align-items: center;
    padding: 2rem 1.5rem;
  }

  .hero-content {
    max-width: 64rem;
    margin: 0 auto;
    width: 100%;
  }

  .hero-portrait {
    margin-bottom: 1.5rem;
  }

  .portrait-img {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 10%;
    display: block;
    border: 3px solid var(--color-primary, #6366f1);
  }

  .hero-greeting {
    color: var(--color-primary, #6366f1);
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-family: "JetBrains Mono", monospace;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .hero-title {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--text-secondary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .hero-bio {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 40rem;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hero-btn.primary {
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    color: white;
  }

  .hero-btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
  }

  .hero-btn.secondary {
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg-card);
  }

  .hero-btn.secondary:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  :global([data-theme="light"]) .portrait-img {
    border-color: var(--border);
  }
</style>
