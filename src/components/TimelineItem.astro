---
interface Props {
  title: string;
  company: string;
  companyUrl?: string;
  period: string;
  description: string;
  delay?: number;
}

const { title, company, companyUrl, period, description, delay = 0 } = Astro.props;
---

<div class="timeline-item animate-on-scroll" style={`transition-delay: ${delay}ms`}>
  <div class="timeline-header">
    <h3 class="timeline-title">{title}</h3>
    <span class="timeline-period">{period}</span>
  </div>
  <p class="timeline-company">
    {companyUrl ? (
      <a href={companyUrl} target="_blank" rel="noopener noreferrer">{company}</a>
    ) : (
      company
    )}
  </p>
  <p class="timeline-description">{description}</p>
</div>

<style>
  .timeline-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .timeline-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .timeline-period {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
  }

  .timeline-company {
    font-size: 0.95rem;
    color: var(--color-primary, #6366f1);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .timeline-company a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .timeline-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }
</style>
